<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Signing for `flutter build ipa`. Manual signing using the profiles `match` installs
  (each named "match AppStore <bundle id>"). Replace YOURTEAMID with your 10-char Team ID.
  Add a line under provisioningProfiles for every extra target you ship.
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>
    <key>signingStyle</key>
    <string>manual</string>
    <key>teamID</key>
    <string>CRRN9GCAL9</string>
    <key>provisioningProfiles</key>
    <dict>
        <key>com.righttechsoft.musicOrganiserRemote</key>
        <string>match AppStore com.righttechsoft.musicOrganiserRemote</string>
    </dict>
    <key>uploadSymbols</key>
    <true/>
    <key>uploadBitcode</key>
    <false/>
</dict>
</plist>
