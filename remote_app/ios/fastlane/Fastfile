default_platform(:ios)

# Bundle ids that ship in the archive. Phone-only for now; add the watch id once its
# target exists in the Xcode project. Keep in sync with Matchfile + ExportOptions.plist.
APP_IDS = [
  "com.righttechsoft.musicOrganiserRemote"
].freeze

platform :ios do
  desc "Build the Flutter app (+ watch) and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true
    )

    # CI: create a throwaway keychain for the signing identity match installs.
    setup_ci
    # setup_ci force-sets MATCH_READONLY=true; undo it so the first run can CREATE the cert.
    ENV["MATCH_READONLY"] = "false"

    # Sync (or, on the first run, CREATE) the distribution cert + one profile per bundle id,
    # storing them in the certs repo. Bootstrap needs readonly:false so the cert is created;
    # once it exists you can flip this to true.
    match(
      type: "appstore",
      app_identifier: APP_IDS,
      readonly: false,
      api_key: api_key
    )

    # Absolute paths only. fastlane's CWD is the fastlane/ dir, and flutter runs xcodebuild
    # from inside ios/, so any relative path breaks. Anchor everything to the fastlane dir.
    build_number = ENV["BUILD_NUMBER"] || "1"
    fastlane_dir = Dir.pwd                                                 # remote_app/ios/fastlane
    export_opts  = File.expand_path("../ExportOptions.plist", fastlane_dir) # remote_app/ios/ExportOptions.plist
    project_dir  = File.expand_path("../..", fastlane_dir)                  # remote_app (has pubspec.yaml)

    sh("cd '#{project_dir}' && flutter build ipa --release " \
       "--build-number=#{build_number} " \
       "--export-options-plist='#{export_opts}'")

    ipa = Dir[File.join(project_dir, "build/ios/ipa/*.ipa")].first
    UI.user_error!("No IPA produced") if ipa.nil?

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true
    )
  end
end
