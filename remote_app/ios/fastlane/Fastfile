default_platform(:ios)

# Bundle ids that ship in the archive. Phone-only for now; add the watch id once its
# target exists in the Xcode project. Keep in sync with Matchfile + ExportOptions.plist.
APP_IDS = [
  "com.righttechsoft.musicOrganiserRemote",
  "com.righttechsoft.musicOrganiserRemote.watchkitapp"
].freeze

platform :ios do
  desc "Build the Flutter app (+ watch) and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true
    )

    # CI: create a throwaway keychain for the signing identity match installs.
    setup_ci
    # setup_ci force-sets MATCH_READONLY=true; undo it so the first run can CREATE the cert.
    ENV["MATCH_READONLY"] = "false"

    # Sync (or, on the first run, CREATE) the distribution cert + one profile per bundle id,
    # storing them in the certs repo. Bootstrap needs readonly:false so the cert is created;
    # once it exists you can flip this to true.
    match(
      type: "appstore",
      app_identifier: APP_IDS,
      readonly: false,
      api_key: api_key
    )

    # Absolute paths only. fastlane's CWD is the fastlane/ dir, and flutter runs xcodebuild
    # from inside ios/, so any relative path breaks. Anchor everything to the fastlane dir.
    build_number = ENV["BUILD_NUMBER"] || "1"
    fastlane_dir = Dir.pwd                                                 # remote_app/ios/fastlane
    export_opts  = File.expand_path("../ExportOptions.plist", fastlane_dir) # remote_app/ios/ExportOptions.plist
    project_dir  = File.expand_path("../..", fastlane_dir)                  # remote_app (has pubspec.yaml)

    # Flutter's default project uses AUTOMATIC signing (no team) — the archive step then
    # can't find a cert on CI. Force the Runner target to MANUAL signing with the match
    # cert + profile before building.
    update_code_signing_settings(
      path: File.expand_path("../Runner.xcodeproj", fastlane_dir),
      use_automatic_signing: false,
      team_id: "CRRN9GCAL9",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.righttechsoft.musicOrganiserRemote",
      profile_name: "match AppStore com.righttechsoft.musicOrganiserRemote",
      targets: ["Runner"]
    )

    # Same, for the watchOS app target (must match the target name in Runner.xcodeproj).
    update_code_signing_settings(
      path: File.expand_path("../Runner.xcodeproj", fastlane_dir),
      use_automatic_signing: false,
      team_id: "CRRN9GCAL9",
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.righttechsoft.musicOrganiserRemote.watchkitapp",
      profile_name: "match AppStore com.righttechsoft.musicOrganiserRemote.watchkitapp",
      targets: ["Watch App"]
    )

    # Do NOT use `flutter build ipa` — its xcodebuild wrapper compiles the embedded watch
    # target's asset catalog under the wrong SDK (actool "AppIcon did not have any applicable
    # content"). Instead let Flutter only write the build number into Generated.xcconfig
    # (--config-only, no xcodebuild), then archive the Runner scheme with gym/xcodebuild
    # directly — that builds the Watch App dependency under the watchOS SDK correctly.
    sh("cd '#{project_dir}' && flutter build ios --config-only --release " \
       "--build-number=#{build_number}")

    ipa = build_app(
      workspace: File.expand_path("../Runner.xcworkspace", fastlane_dir),
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: export_opts,
      output_directory: File.join(project_dir, "build/ios/ipa"),
      output_name: "Runner.ipa",
      clean: true
    )
    UI.user_error!("No IPA produced") if ipa.nil?

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true
    )
  end
end
