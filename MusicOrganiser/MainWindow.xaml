<Window x:Class="MusicOrganiser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:MusicOrganiser.Converters"
        xmlns:controls="clr-namespace:MusicOrganiser.Controls"
        mc:Ignorable="d"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Icon="logo.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NowPlayingConverter x:Key="NowPlayingConverter"/>
        <converters:NowPlayingBoolConverter x:Key="NowPlayingBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:TitleConverter x:Key="TitleConverter"/>
        <converters:PlayingFolderFontWeightConverter x:Key="PlayingFolderFontWeightConverter"/>

        <Style x:Key="PlayerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Window.Title>
        <MultiBinding Converter="{StaticResource TitleConverter}">
            <Binding Path="CurrentFolderPath"/>
            <Binding Path="NowPlaying"/>
        </MultiBinding>
    </Window.Title>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Folders + Playlists tabs -->
        <TabControl Grid.Column="0">
        <TabItem Header="Folders">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TreeView x:Name="FolderTreeView" Grid.Row="0"
                      ItemsSource="{Binding FolderTree.RootNodes}"
                      SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingStackPanel.IsVirtualizing="False">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                        <EventSetter Event="MouseRightButtonDown" Handler="TreeViewItem_MouseRightButtonDown"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel x:Name="FolderRow" Orientation="Horizontal" Background="Transparent">
                            <Button Content="&#x25B6;" FontSize="10" Padding="3,0" Margin="0,0,2,0"
                                    VerticalAlignment="Center" Cursor="Hand" Background="Transparent"
                                    BorderThickness="0" Foreground="#2E7D32"
                                    ToolTip="Play this folder and all subfolders"
                                    Command="{Binding DataContext.PlayFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=FolderRow}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding Name}" Padding="2" VerticalAlignment="Center">
                                <TextBlock.FontWeight>
                                    <MultiBinding Converter="{StaticResource PlayingFolderFontWeightConverter}">
                                        <Binding Path="FullPath"/>
                                        <Binding Path="DataContext.NowPlaying.FullPath" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </TextBlock.FontWeight>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                <Setter Property="Foreground" Value="Gray"/>
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <controls:StarRating Rating="{Binding Rating, Mode=TwoWay}"
                                                 EditMode="{Binding IsMouseOver, ElementName=FolderRow}"
                                                 VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <TextBlock Text="{Binding Tags}" VerticalAlignment="Center"
                                       FontSize="10" Foreground="#777777" Margin="6,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=FolderRow}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding Tags, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Width="90" FontSize="10" Padding="2,0"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     Margin="6,0,0,0" Background="Transparent" BorderBrush="#DDDDDD"
                                     ToolTip="Comma-separated tags">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=FolderRow}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.ContextMenu>
                    <ContextMenu x:Name="FolderContextMenu" Opened="FolderContextMenu_Opened">
                        <MenuItem Header="Refresh" Click="FolderRefresh_Click"/>
                        <Separator/>
                        <MenuItem x:Name="FolderCopyToMenu" Header="Copy To"/>
                        <MenuItem x:Name="FolderMoveToMenu" Header="Move To"/>
                        <Separator/>
                        <MenuItem x:Name="FolderAddToPlaylistMenu" Header="Add Folder to Playlist"/>
                        <Separator/>
                        <MenuItem Header="Delete" Click="FolderDelete_Click"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>

            <!-- Filter and Sort Panel -->
            <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0"
                             Text="{Binding FolderTree.FilterText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter folders"
                             Margin="0,0,0,5"/>
                    <ComboBox Grid.Row="1"
                              ItemsSource="{Binding FolderTree.SortOptions}"
                              SelectedItem="{Binding FolderTree.SelectedSortOption}"
                              ToolTip="Sort folders by"/>
                </Grid>
            </Border>
        </Grid>
        </TabItem>

        <!-- Playlists Tab -->
        <TabItem Header="Playlists">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Content="+ New Playlist" Margin="5" Padding="4"
                        Click="NewPlaylist_Click"/>

                <ListBox x:Name="PlaylistListBox" Grid.Row="1"
                         ItemsSource="{Binding Playlists}"
                         SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                         SelectionChanged="PlaylistListBox_SelectionChanged"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="PlaylistItem_PreviewMouseRightButtonDown"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding TrackCount}"
                                           VerticalAlignment="Center"
                                           Foreground="#999999" FontSize="11" Margin="6,0,2,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Rename" Click="PlaylistRename_Click"/>
                            <MenuItem Header="Delete" Click="PlaylistDelete_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </Grid>
        </TabItem>
        </TabControl>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- Right Panel: Music Grid + Player -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Recent Played Folders -->
            <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                    Visibility="{Binding RecentPlayedFolders.Count, Converter={StaticResource CountToVisibilityConverter}}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="4">
                    <ItemsControl ItemsSource="{Binding RecentPlayedFolders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1"
                                        CornerRadius="3" Margin="2" Padding="6,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Cursor="Hand"
                                                   Foreground="#1565C0"
                                                   VerticalAlignment="Center"
                                                   Tag="{Binding FullPath}"
                                                   MouseLeftButtonUp="RecentFolder_Click"
                                                   ToolTip="{Binding FullPath}"/>
                                        <Button Content="&#10005;"
                                                Width="16" Height="16"
                                                FontSize="9"
                                                Padding="0"
                                                Margin="6,0,0,0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Foreground="#777777"
                                                Cursor="Hand"
                                                Tag="{Binding FullPath}"
                                                Click="RemoveRecentFolder_Click"
                                                ToolTip="Remove from list"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Music Files Grid (with album cover behind) -->
            <Grid Grid.Row="1" x:Name="CoverHost" SizeChanged="CoverHost_SizeChanged"
                  MouseLeftButtonUp="CoverHost_MouseLeftButtonUp">
            <!-- Album Cover (behind the file list) -->
            <Image x:Name="AlbumCoverImage"
                   Source="{Binding AlbumCover}"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   MaxWidth="450" MaxHeight="450"
                   Margin="40,0,40,0"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SizeChanged="AlbumCoverImage_SizeChanged"/>

            <DataGrid x:Name="MusicFilesGrid"
                      Background="Transparent"
                      ItemsSource="{Binding MusicFiles}"
                      SelectedItem="{Binding SelectedFile}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="None"
                      AlternationCount="2"
                      MouseDoubleClick="MusicFilesGrid_MouseDoubleClick">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource NowPlayingConverter}">
                                    <Binding />
                                    <Binding Path="DataContext.NowPlaying" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#BEF0F0F0"/>
                            </Trigger>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource NowPlayingBoolConverter}">
                                        <Binding />
                                        <Binding Path="DataContext.NowPlaying" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Background" Value="#C8E6FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="Album" Binding="{Binding Album}" Width="*" MinWidth="100"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding DurationFormatted}" Width="70"/>
                    <DataGridTextColumn Header="Bitrate" Binding="{Binding BitrateFormatted}" Width="80"/>
                    <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="80"/>
                    <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="50"/>
                    <DataGridTemplateColumn Header="Rating" Width="90" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <controls:StarRating Rating="{Binding Rating, Mode=TwoWay}"
                                                     EditMode="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Tags" Width="160" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding Tags}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Foreground="#777777">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding Tags, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalAlignment="Center"
                                             ToolTip="Comma-separated tags">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu x:Name="FileContextMenu" Opened="FileContextMenu_Opened"
                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem x:Name="FileCopyToMenu" Header="Copy To"/>
                        <MenuItem x:Name="FileMoveToMenu" Header="Move To"/>
                        <Separator/>
                        <MenuItem x:Name="FileAddToPlaylistMenu" Header="Add to Playlist"/>
                        <MenuItem Header="New Playlist from Selection" Click="NewPlaylistFromSelection_Click"/>
                        <Separator/>
                        <MenuItem Header="Remove from Playlist" Click="RemoveFromPlaylist_Click"
                                  IsEnabled="{Binding IsPlaylistView}"/>
                        <MenuItem Header="Move Up" Click="MoveEntryUp_Click"
                                  IsEnabled="{Binding IsPlaylistView}"/>
                        <MenuItem Header="Move Down" Click="MoveEntryDown_Click"
                                  IsEnabled="{Binding IsPlaylistView}"/>
                        <Separator/>
                        <MenuItem Header="Delete" Click="FileDelete_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <!-- Loading overlay -->
            <Border Background="#80FFFFFF" IsHitTestVisible="False"
                    Visibility="{Binding IsLoadingFiles, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="180" Height="6"/>
                    <TextBlock Text="Loading files…" HorizontalAlignment="Center"
                               Margin="0,8,0,0" Foreground="#555555"/>
                </StackPanel>
            </Border>
            </Grid>

            <!-- Audio Player Control -->
            <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Player Controls (70%) -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Now Playing Info -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding NowPlaying.FileName, FallbackValue='No file playing'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,10,5"/>

                        <!-- Progress Slider -->
                        <Grid Grid.Row="1" Margin="0,5,10,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CurrentPositionFormatted}" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1"
                                    x:Name="ProgressBar"
                                    Minimum="0" Maximum="100"
                                    Value="{Binding SliderValue, Mode=OneWay}"
                                    Margin="10,0"
                                    Height="20"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="ProgressBar_MouseLeftButtonDown"/>
                            <TextBlock Grid.Column="2" Text="{Binding TotalDurationFormatted}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Control Buttons and Volume -->
                        <Grid Grid.Row="2" Margin="0,10,10,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Command="{Binding ToggleShuffleCommand}" ToolTip="Shuffle" Content="&#x1F500;">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShuffleEnabled}" Value="True">
                                                    <Setter Property="Background" Value="#90CAF9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="&#9664;&#9664;" Style="{StaticResource PlayerButtonStyle}"
                                        Command="{Binding PreviousCommand}" ToolTip="Previous"/>
                                <Button Style="{StaticResource PlayerButtonStyle}"
                                        Command="{Binding PlayPauseCommand}" ToolTip="Play/Pause">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#9654;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                            <Setter Property="Text" Value="&#10074;&#10074;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                                <Button Content="&#9632;" Style="{StaticResource PlayerButtonStyle}"
                                        Command="{Binding StopCommand}" ToolTip="Stop"/>
                                <Button Content="&#9654;&#9654;" Style="{StaticResource PlayerButtonStyle}"
                                        Command="{Binding NextCommand}" ToolTip="Next"/>
                                <Button Command="{Binding CycleRepeatCommand}" ToolTip="Repeat"
                                        Content="{Binding RepeatGlyph}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                            <Setter Property="Foreground" Value="#BBBBBB"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RepeatActive}" Value="True">
                                                    <Setter Property="Background" Value="#90CAF9"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Remote playback indicator (audio streaming to the phone) -->
                            <Border Grid.Column="1" Background="#1E88E5" CornerRadius="4"
                                    Padding="8,3" Margin="10,0" VerticalAlignment="Center"
                                    Visibility="{Binding RemoteSink, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#x1F4F1; Remote playback" Foreground="White"
                                           FontWeight="SemiBold" FontSize="12"/>
                            </Border>

                            <!-- Output Device + Volume Controls -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- Output device selector -->
                                <ComboBox x:Name="OutputDeviceBox"
                                          Width="150" Height="22"
                                          VerticalAlignment="Center" Margin="0,0,10,0"
                                          ItemsSource="{Binding OutputDevices}"
                                          SelectedItem="{Binding SelectedOutputDevice, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          ToolTip="Output device"/>
                                <!-- System (Windows master) volume -->
                                <TextBlock Text="&#x1F310;" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ProgressBar x:Name="SystemVolumeBar"
                                             Width="80" Height="20"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding SystemVolume, Mode=OneWay}"
                                             Cursor="Hand"
                                             ToolTip="System volume (whole PC)"
                                             Margin="0,0,15,0"
                                             MouseLeftButtonDown="SystemVolumeBar_MouseLeftButtonDown"
                                             MouseMove="SystemVolumeBar_MouseMove"
                                             MouseLeftButtonUp="SystemVolumeBar_MouseLeftButtonUp"/>
                                <!-- In-app volume -->
                                <TextBlock Text="&#128266;" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ProgressBar x:Name="VolumeBar"
                                             Width="80" Height="20"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding Volume, Mode=OneWay}"
                                             Cursor="Hand"
                                             ToolTip="App volume"
                                             MouseLeftButtonDown="VolumeBar_MouseLeftButtonDown"
                                             MouseMove="VolumeBar_MouseMove"
                                             MouseLeftButtonUp="VolumeBar_MouseLeftButtonUp"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Right: AI Artist Summary (30%) -->
                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Padding="10,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding ArtistSummary, FallbackValue='Select a track to see artist info'}"
                                       FontSize="11"
                                       Foreground="#555555"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"/>
                            <Button Grid.Column="1" Content="&#8635;" FontSize="14" Padding="5,2"
                                    Command="{Binding RefreshArtistInfoCommand}"
                                    ToolTip="Load artist info"
                                    VerticalAlignment="Top"
                                    IsEnabled="{Binding NowPlaying, Converter={StaticResource NullToBoolConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Album cover zoom overlay: click cover to enlarge, click anywhere to dismiss -->
        <Border x:Name="CoverZoomOverlay" Grid.Column="0" Grid.ColumnSpan="3"
                Background="#E6101010" Visibility="Collapsed" Cursor="Hand"
                MouseLeftButtonUp="CoverZoomOverlay_MouseLeftButtonUp">
            <Image Source="{Binding AlbumCover}" Stretch="Uniform" Margin="20"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>
    </Grid>
</Window>
